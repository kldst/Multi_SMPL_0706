{
  // ------------------------------------------------------------------
  // Keep VSCode from crawling / watching the multi-GB training outputs.
  // The .gitignore does NOT affect the file watcher (it ignores .gitignore
  // by default), so these heavy dirs must be excluded explicitly here or
  // the extension host OOMs while checkpoints are being written.
  // ------------------------------------------------------------------

  // File watcher: the OOM culprit. Stops inotify watches + startup crawl.
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/__pycache__/**": true,
    "**/training/logs/**": true,
    "**/logs/**": true,
    "**/ckpts/**": true,
    "**/checkpoints/**": true,
    "**/.gradio_cache/**": true,
    "**/.gradio/**": true,
    "**/wandb/**": true,
    "**/tensorboard/**": true,
    "**/debug_outputs/**": true,
    "**/attn_out/**": true,
    "**/attn_out_mv/**": true,
    "**/ckpt/**": true,
    "**/smpl_models/**": true,
    "**/smplx_models/**": true,
    "**/*.pt": true,
    "**/*.pth": true,
    "**/*.ckpt": true,
    "**/*.safetensors": true
  },

  // Search: skip the same heavy trees (search already honors .gitignore,
  // this is belt-and-suspenders for anything not gitignored).
  "search.exclude": {
    "**/training/logs/**": true,
    "**/logs/**": true,
    "**/ckpts/**": true,
    "**/checkpoints/**": true,
    "**/.gradio_cache/**": true,
    "**/.gradio/**": true,
    "**/debug_outputs/**": true,
    "**/attn_out/**": true,
    "**/attn_out_mv/**": true,
    "**/ckpt/**": true,
    "**/*.pt": true,
    "**/*.pth": true,
    "**/*.ckpt": true,
    "**/*.safetensors": true
  },

  // Hide the heavy trees from the Explorer so you can't accidentally open
  // a 13GB checkpoint in the editor (the other easy way to OOM).
  "files.exclude": {
    "**/__pycache__": true,
    "**/training/logs": true,
    "**/.gradio_cache": true,
    "**/.gradio": true,
    "**/debug_outputs": true,
    "**/attn_out": true,
    "**/attn_out_mv": true
  },

  // Pylance: don't let language-server indexing walk the big output dirs.
  "python.analysis.exclude": [
    "**/training/logs/**",
    "**/logs/**",
    "**/ckpts/**",
    "**/.gradio_cache/**",
    "**/debug_outputs/**",
    "**/attn_out/**",
    "**/attn_out_mv/**"
  ]
}
